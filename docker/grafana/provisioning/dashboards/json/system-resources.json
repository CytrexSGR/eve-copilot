{
  "title": "System Resources",
  "uid": "eve-system-resources",
  "tags": ["microservices", "resources", "database", "cache", "eve-copilot"],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "refresh": "30s",
  "schemaVersion": 38,
  "version": 2,
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "label": "Service",
        "description": "Select service(s) to filter",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(db_connections, service)",
        "multi": true,
        "includeAll": true,
        "current": {
          "text": "All",
          "value": ["$__all"]
        },
        "refresh": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Database Connection Pool - Total",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(db_connections{service=~\"$service\", state=\"active\"}) by (service)",
          "legendFormat": "{{service}} - Active",
          "refId": "A"
        },
        {
          "expr": "sum(db_connections{service=~\"$service\", state=\"idle\"}) by (service)",
          "legendFormat": "{{service}} - Idle",
          "refId": "B"
        },
        {
          "expr": "sum(db_connections{service=~\"$service\", state=\"waiting\"}) by (service)",
          "legendFormat": "{{service}} - Waiting",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "stacking": {
              "mode": "normal"
            }
          },
          "unit": "short",
          "min": 0
        },
        "overrides": [
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".*Active.*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "green"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".*Idle.*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "blue"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".*Waiting.*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "red"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["last", "mean", "max"]
        }
      }
    },
    {
      "id": 2,
      "title": "Connection Pool by Service",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "expr": "db_connections{service=~\"$service\"}",
          "legendFormat": "{{service}} - {{state}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 0
          },
          "unit": "short",
          "min": 0
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["last", "mean"]
        }
      }
    },
    {
      "id": 3,
      "title": "Active Connections (Current)",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "expr": "sum(db_connections{service=~\"$service\", state=\"active\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              },
              {
                "value": 10,
                "color": "yellow"
              },
              {
                "value": 15,
                "color": "red"
              }
            ]
          },
          "unit": "short"
        }
      },
      "options": {
        "graphMode": "area",
        "colorMode": "value",
        "textMode": "value_and_name"
      }
    },
    {
      "id": 4,
      "title": "Idle Connections (Current)",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 8
      },
      "targets": [
        {
          "expr": "sum(db_connections{service=~\"$service\", state=\"idle\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "blue"
              }
            ]
          },
          "unit": "short"
        }
      },
      "options": {
        "graphMode": "area",
        "colorMode": "value",
        "textMode": "value_and_name"
      }
    },
    {
      "id": 5,
      "title": "Waiting Connections (Current)",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 8
      },
      "targets": [
        {
          "expr": "sum(db_connections{service=~\"$service\", state=\"waiting\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              },
              {
                "value": 1,
                "color": "orange"
              },
              {
                "value": 5,
                "color": "red"
              }
            ]
          },
          "unit": "short"
        }
      },
      "options": {
        "graphMode": "area",
        "colorMode": "value",
        "textMode": "value_and_name"
      }
    },
    {
      "id": 6,
      "title": "Pool Utilization %",
      "type": "gauge",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 8
      },
      "targets": [
        {
          "expr": "(sum(db_connections{service=~\"$service\", state=\"active\"}) / (sum(db_connections{service=~\"$service\", state=\"active\"}) + sum(db_connections{service=~\"$service\", state=\"idle\"}))) * 100",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "percentage",
            "steps": [
              {
                "value": null,
                "color": "green"
              },
              {
                "value": 50,
                "color": "yellow"
              },
              {
                "value": 80,
                "color": "red"
              }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      },
      "options": {
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      }
    },
    {
      "id": 7,
      "title": "Database Query Rate",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "targets": [
        {
          "expr": "sum(rate(db_queries_total{service=~\"$service\"}[5m])) by (service)",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10
          },
          "unit": "qps",
          "min": 0
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["last", "mean", "max"]
        }
      }
    },
    {
      "id": 8,
      "title": "Database Query Duration (P95)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(db_query_duration_seconds_bucket{service=~\"$service\"}[5m])) by (service, le))",
          "legendFormat": "{{service}} P95",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(db_query_duration_seconds_bucket{service=~\"$service\"}[5m])) by (service, le))",
          "legendFormat": "{{service}} P99",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 0
          },
          "unit": "s",
          "min": 0
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["last", "mean", "max"]
        }
      }
    },
    {
      "id": 9,
      "title": "Cache Metrics - Coming Soon",
      "type": "text",
      "gridPos": {
        "h": 6,
        "w": 24,
        "x": 0,
        "y": 20
      },
      "options": {
        "mode": "markdown",
        "content": "## Cache Metrics - Pending Instrumentation\n\n**Status**: 🟡 Cache operations (`cache_operations_total`) are defined but not yet instrumented.\n\n**Planned Metrics**:\n- Cache hit rate by service\n- Cache operations per second\n- Cache miss ratio\n\n**Next Step**: Instrument Redis operations in services with `eve_shared.metrics.cache_operations_total`."
      }
    }
  ]
}
