[Unit]
Description=ECTMap Service
After=network.target

[Service]
Type=simple
User=cytrex
WorkingDirectory=/home/cytrex/eve_copilot/services/ectmap-service
Environment="PATH=/home/cytrex/eve_copilot/services/ectmap-service/venv/bin"
Environment="SNAPSHOT_DIR=/var/www/snapshots"
EnvironmentFile=/home/cytrex/eve_copilot/.env
Environment="DATABASE_URL=postgresql://eve:${DB_PASSWORD}@localhost/eve_sde"
ExecStart=/home/cytrex/eve_copilot/services/ectmap-service/venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8011
Restart=always

[Install]
WantedBy=multi-user.target
